{
  "name": "detwilertech",
  "version": "0.1.0",
  "description": "Detwiler Tech B2B corporate website — Next.js 15 + Payload CMS 3 + next-intl",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:clean": "node scripts/dev-clean.js",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:clean": "rimraf .next && cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "scrape:cobtel": "node scripts/scrape-cobtel.mjs",
    "scan:products": "node scripts/scan-products.mjs",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap"
  },
  "dependencies": {
    "next": "15.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "payload": "3.20.0",
    "@payloadcms/next": "3.20.0",
    "@payloadcms/db-sqlite": "3.20.0",
    "@payloadcms/db-postgres": "3.20.0",
    "@payloadcms/richtext-lexical": "3.20.0",
    "@payloadcms/ui": "3.20.0",
    "next-intl": "3.25.0",
    "react-hook-form": "^7.53.0",
    "@hookform/resolvers": "^3.9.0",
    "zod": "^3.23.8",
    "lucide-react": "^0.460.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "sonner": "^1.5.0",
    "sharp": "^0.33.5",
    "resend": "^4.0.0",
    "@react-email/components": "^0.0.28",
    "@react-email/render": "^1.0.1",
    "graphql": "^16.9.0",
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "tailwindcss": "^3.4.13",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.1.6",
    "playwright": "^1.48.0",
    "cheerio": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
