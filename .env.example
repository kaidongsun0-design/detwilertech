# ===== Detwiler Tech 环境变量模板 =====
# 复制为 .env 并填入实际值。.env 不要提交到 git。

# ---- Payload 核心 ----
PAYLOAD_SECRET=replace-with-random-32-char-string
DATABASE_URI=file:./data/payload.db
# 生产用 PostgreSQL:
# DATABASE_URI=postgres://user:pass@host:5432/detwilertech

# ---- 站点信息 ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Detwiler Tech

# ---- 销售与联系（用于询盘邮件、WhatsApp 链接、Footer 显示） ----
NEXT_PUBLIC_SALES_EMAIL=sales@detwilertech.com
NEXT_PUBLIC_INFO_EMAIL=info@detwilertech.com
NEXT_PUBLIC_WHATSAPP_NUMBER=8613800000000   # 国际格式，无 +
NEXT_PUBLIC_PHONE=+86-138-0000-0000
NEXT_PUBLIC_ADDRESS=Shenzhen, Guangdong, China

# ---- 邮件服务 ----
# Resend（海外/海外客户）
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@detwilertech.com

# 阿里云 DirectMail（国内收件人）
DIRECTMAIL_ACCESS_KEY=
DIRECTMAIL_ACCESS_SECRET=
DIRECTMAIL_REGION=cn-hangzhou
DIRECTMAIL_FROM_ADDRESS=noreply@detwilertech.com
DIRECTMAIL_FROM_NAME=Detwiler Tech

# ---- Cloudflare Turnstile（防垃圾）----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- 文件存储（生产）----
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=detwilertech-media
S3_REGION=auto

# ---- Sentry（可选监控）----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
